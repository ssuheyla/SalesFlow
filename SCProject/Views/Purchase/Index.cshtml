@{
    ViewData["Title"] = "Satın Alma";
}

<h2> Satın Alma Ekranı</h2>

<div id="purchaseGrid"></div>

@section Scripts {
    <script>
        $(function () {
            $("#purchaseGrid").dxDataGrid({
                dataSource: new DevExpress.data.CustomStore({
                    key: "ID",
                    load: function () {
                        return $.getJSON("/Purchase/getPurchase");
                    },
                    insert: function (values) {
                        return $.ajax({
                            url: "/Purchase/AddPurchase",
                            method: "POST",
                            data: { values: JSON.stringify(values) }
                        });
                    },
                    update: function (key, values) {
                        return $.ajax({
                            url: "/Purchase/UpdatePurchase",
                            method: "PUT",
                            data: { key: key, values: JSON.stringify(values) }
                        });
                    },
                    remove: function (key) {
                        return $.ajax({
                            url: "/Purchase/DeletePurchase",
                            method: "DELETE",
                            data: { key: key }
                        });
                    }
                }),

                columns: [
                    {
                        dataField: "ID",
                        caption: "ID",
                        width: 70,
                        allowEditing: false
                    },
                    {
                        dataField: "PRODUCT_ID",
                        caption: "Ürün",
                        lookup: {
                            dataSource: {
                                store: new DevExpress.data.CustomStore({
                                    key: "ID",
                                    loadMode: "raw",
                                    load: function () {
                                        return $.getJSON("/Purchase/getProduct");
                                    }
                                })
                            },
                            valueExpr: "ID",
                            displayExpr: "NAME"
                        }
                    },
                    {
                        dataField: "CUSTOMER_ID",
                        caption: "Tedarikçi",
                        lookup: {
                            dataSource: {
                                store: new DevExpress.data.CustomStore({
                                    key: "ID",
                                    loadMode: "raw",
                                    load: function () {
                                        return $.getJSON("/Purchase/GetCustomers");
                                    }
                                })
                            },
                            valueExpr: "ID",
                            displayExpr: "CUSTOMERTITLE"
                        }
                    },
                    {
                        dataField: "QUANTITY",
                        caption: "Miktar",
                        dataType: "number"
                    },
                    {
                        dataField: "PRICE",
                        caption: "Birim Fiyat",
                        dataType: "number",
                        format: { type: "fixedPoint", precision: 2 }
                    },
                    {
                        dataField: "AMOUNT",
                        caption: "Toplam Tutar",
                        dataType: "number",
                        format: { type: "fixedPoint", precision: 2 },
                        allowEditing: false
                    },
                    {
                        dataField: "DATE",
                        caption: "Tarih",
                        dataType: "date",
                        format: "dd.MM.yyyy"
                    }
                ],

                // Miktar veya fiyat değişince tutarı hesapla
                onEditorPreparing: function (e) {
                    if (e.parentType !== "dataRow") return;

                    if (e.dataField === "QUANTITY") {
                        var defaultOnChanged = e.editorOptions.onValueChanged;
                        e.editorOptions.onValueChanged = function (args) {
                            defaultOnChanged && defaultOnChanged(args);
                            var grid = e.component;
                            var price = grid.cellValue(e.row.rowIndex, "PRICE");
                            if (price) {
                                grid.cellValue(e.row.rowIndex, "AMOUNT", args.value * price);
                            }
                        };
                    }

                    if (e.dataField === "PRICE") {
                        var defaultOnChanged2 = e.editorOptions.onValueChanged;
                        e.editorOptions.onValueChanged = function (args) {
                            defaultOnChanged2 && defaultOnChanged2(args);
                            var grid = e.component;
                            var quantity = grid.cellValue(e.row.rowIndex, "QUANTITY");
                            if (quantity) {
                                grid.cellValue(e.row.rowIndex, "AMOUNT", quantity * args.value);
                            }
                        };
                    }
                },

                showBorders: true,
                showRowLines: true,
                rowAlternationEnabled: true,              
                paging: { pageSize: 20 },
                pager: {
                    showPageSizeSelector: true,
                    allowedPageSizes: [10, 15, 25, 50],
                    showInfo: true
                },

                editing: {
                    mode: "popup",
                    allowAdding: true,
                    allowUpdating: true,
                    allowDeleting: true,
                    popup: {
                        title: "Satın Alma Bilgileri",
                        showTitle: true,
                        width: 700,
                        height: 450
                    }
                },

                onRowInserted: function () {
                    DevExpress.ui.notify("Satın alma kaydı eklendi, stok güncellendi.", "success", 2000);
                },
                onRowUpdated: function () {
                    DevExpress.ui.notify("Satın alma kaydı güncellendi.", "success", 2000);
                },
                onRowRemoved: function () {
                    DevExpress.ui.notify("Satın alma kaydı silindi.", "success", 2000);
                }
            });
        });
    </script>
}